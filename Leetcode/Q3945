class Solution {
    public int digitFrequencyScore(int n) {
        int[] hash=new int[10];

        while(n>0){
            int digit=n%10;
            n=n/10;
            hash[digit]++;
        }

        int sum=0;
        for(int i=0;i<10;i++){
            sum=sum+(i*hash[i]);
        }

        return sum;
    }
}
