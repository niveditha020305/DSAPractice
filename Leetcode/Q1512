class Solution {
    public int numIdenticalPairs(int[] nums) {
        int[] freq=new int[101];

        for(int i=0;i<nums.length;i++){
            freq[nums[i]]++;
        }

        int total=0;

        for(int i=0;i<10;i++){
            if(freq[i]>0){
                total+=(freq[i]*(freq[i]-1))/2;
            }
        }


        return total;
    }
}
