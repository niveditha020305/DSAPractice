class Solution {
    public int[] getSneakyNumbers(int[] nums) {
        int n=nums.length-2;
        int[] freq=new int[n];
        int[] ans=new int[2];

        for(int i=0;i<nums.length;i++){
            freq[nums[i]]++;
        }

        int j=0;
        for(int i=0;i<n;i++){
            if(freq[i]>1){
                ans[j]=i;
                j++;
            }
        }

        return ans;

    }
}
