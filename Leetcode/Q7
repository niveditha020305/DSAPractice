class Solution {
    public int reverse(int x) {
       long rev=0;
       int ori=x;

        while(x!=0){
            int digit=x%10;
            rev=rev*10+digit;
            x=x/10; 
        }

        
        if(rev > Integer.MAX_VALUE || rev < Integer.MIN_VALUE){
           return 0;
        }
        else{
            int res=(int)rev;
            return res;
            
        }

        
    }
}
