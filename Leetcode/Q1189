class Solution {
    public int maxNumberOfBalloons(String text) {
        int[] freq=new int[26];

        for(char ch : text.toCharArray()){
            freq[ch - 'a']++;
        }

        int b = freq['b' - 'a'];
        int a = freq['a' - 'a'];
        int l = freq['l' - 'a'];
        int o = freq['o' - 'a'];
        int n = freq['n' - 'a'];

        int min=Math.min(Math.min(b,a),Math.min(l/2,Math.min(o/2,n)));

        return min;
    }
    
}
